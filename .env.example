# Firebase Configuration
# Get these from Firebase Console > Project Settings > General > Your apps > Web app > Config
# Create a new web app if needed, then copy-paste here.

REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=yourproject.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=yourproject
REACT_APP_FIREBASE_STORAGE_BUCKET=yourproject.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Copy this file to .env (no 'example') and fill values.
# Never commit .env to git!
# Then npm start

