rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function serviceAllowsPublicCheckin(serviceId) {
      return exists(/databases/$(database)/documents/services/$(serviceId)) &&
        get(/databases/$(database)/documents/services/$(serviceId)).data.publicCheckIn == true;
    }

    match /members/{memberId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() ||
        (resource.data.serviceId is string && serviceAllowsPublicCheckin(resource.data.serviceId));
      allow create: if isSignedIn() ||
        (request.resource.data.serviceId is string && serviceAllowsPublicCheckin(request.resource.data.serviceId));
      allow update, delete: if isSignedIn();
    }

    match /alerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    match /notification_templates/{templateId} {
      allow read, write: if isSignedIn();
    }

    match /memberProgress/{progressId} {
      allow read, write: if isSignedIn();
    }
  }
}
